---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Grid from '~/components/Grid.astro';
import ArticleCard from '~/components/ArticleCard.astro';
import { articleHref } from '~/utils/site';

const entries = (await getCollection('hobbies', ({ data }) => !data.draft))
  .sort((a, b) => +b.data.date - +a.data.date);
---

<BaseLayout title="Hobbies" description="Watercolor, mountains, books and other pastimes.">
  <section class="container">
    <header class="page-header">
      <h1>Hobbies</h1>
      <p>Watercolor, mountains, books — life outside the screen.</p>
    </header>
    <Grid>
      {entries.map((e) => (
        <ArticleCard
          href={articleHref('hobbies', e.id)}
          title={e.data.title}
          description={e.data.description}
          date={e.data.date}
          cover={e.data.cover}
          coverAlt={e.data.coverAlt}
          section="hobbies"
          tags={e.data.tags}
        />
      ))}
    </Grid>
    {entries.length === 0 && <p class="empty">Nothing here yet.</p>}
  </section>

  <style>
    .page-header { margin-bottom: 1.5rem; }
    .page-header p { color: var(--text-muted); }
    .empty { color: var(--text-muted); }
  </style>
</BaseLayout>
