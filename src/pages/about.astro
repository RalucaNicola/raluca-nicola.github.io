---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About this site.">
  <section class="reading about">
    <h1>About</h1>
    <p>
      A small corner of the internet for writings and drawings. I'm interested in
      maps, charts, and the things you notice when you sit with data long enough.
    </p>
    <p>
      Built with <a href="https://astro.build">Astro</a>. Source is on
      <a href="#">GitHub</a> (update this link in <code>src/pages/about.astro</code>).
    </p>
  </section>
</BaseLayout>

<style>
  .about { padding-top: 1rem; }
</style>
