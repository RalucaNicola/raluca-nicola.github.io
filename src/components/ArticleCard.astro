---
import { type Section } from '~/utils/site';

interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  cover?: string;
  coverAlt?: string;
  section?: Section;
  tags?: string[];
}

const { href, title, description, date, cover, coverAlt, tags = [] } = Astro.props;
const dateLabel = date.toLocaleDateString('en-US', { year: '2-digit', month: 'short' });
const category = tags.join(' · ');
const base = import.meta.env.BASE_URL;
const coverSrc = cover
  ? (cover.startsWith('http') ? cover : (base + cover).replace(/\/+/g, '/'))
  : undefined;
---

<a class="item" href={href} aria-label={title}>
  <div class="thumb">
    {coverSrc ? (
      <img class="layer" src={coverSrc} alt={coverAlt ?? ''} loading="lazy" decoding="async" />
    ) : (
      <div class="layer cover-fallback" aria-hidden="true">{tags[0] ?? ''}</div>
    )}
  </div>
  <div class="info">
    <time class="date" datetime={date.toISOString()}>{dateLabel}</time>
    <h3>{title}</h3>
  </div>
  {category && <div class="cat">{category}</div>}
  <p class="desc">{description}</p>
</a>

<style>
  .item {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .item:hover { text-decoration: none; }

  .thumb {
    aspect-ratio: 4 / 3;
    position: relative;
    overflow: hidden;
    background: var(--accent-soft);
  }
  /* grayscale paper that drinks in color on hover */
  .thumb .layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.9) contrast(0.92) brightness(1.04);
    transition:
      filter 0.7s cubic-bezier(0.2, 0.6, 0.2, 1),
      transform 0.7s cubic-bezier(0.2, 0.6, 0.2, 1);
    transform: scale(1.01);
  }
  .item:hover .thumb .layer {
    filter: grayscale(0) contrast(1) brightness(1);
    transform: scale(1.04);
  }
  .item:hover .thumb::after { opacity: 1; }

  .cover-fallback {
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    color: var(--accent);
    font-size: 1.1rem;
    letter-spacing: 0.04em;
    filter: none;
  }

  .info {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-top: 18px;
  }
  .info .date {
    font-size: 0.75rem;
    color: var(--text-muted);
    min-width: 56px;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
  }
  .info h3 {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin: 0;
  }
  .cat {
    font-size: 0.6875rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 9px 0 0 70px;
  }
  .desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0 0 0 70px;
    max-width: 340px;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, opacity 0.4s ease, margin-top 0.4s ease;
  }
  .item:hover .desc {
    max-height: 80px;
    opacity: 1;
    margin-top: 8px;
  }

  @media (max-width: 680px) {
    .thumb .layer { filter: grayscale(0); }
    .desc { max-height: none; opacity: 1; margin-top: 8px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .thumb .layer { transition: none; }
  }
</style>
