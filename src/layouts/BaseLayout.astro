---
import '~/styles/global.css';
import Nav from '~/components/Nav.astro';
import Footer from '~/components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
}

const SITE_NAME = 'Raluca Nicola';
const DEFAULT_OG_IMAGE = '/images/og-image.png';

const {
  title,
  description = 'Visual explorations by Raluca Nicola.',
  ogImage,
  ogImageAlt,
  ogType = 'website',
  publishedTime,
} = Astro.props;

const fullTitle = title === SITE_NAME ? title : `${title} · ${SITE_NAME}`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const ogImageSrc = ogImage ?? DEFAULT_OG_IMAGE;
const ogImageUrl = ogImageSrc.startsWith('http')
  ? ogImageSrc
  : new URL((import.meta.env.BASE_URL + ogImageSrc).replace(/\/+/g, '/'), Astro.site).toString();

// --- JSON-LD structured data ---
const SITE_URL = new URL(import.meta.env.BASE_URL, Astro.site).toString();
const SAME_AS = ['https://github.com/ralucanicola'];

const person = {
  '@type': 'Person',
  '@id': `${SITE_URL}#person`,
  name: SITE_NAME,
  url: SITE_URL,
  sameAs: SAME_AS,
};

const website = {
  '@type': 'WebSite',
  '@id': `${SITE_URL}#website`,
  url: SITE_URL,
  name: SITE_NAME,
  description: 'Visual explorations by Raluca Nicola.',
  publisher: { '@id': `${SITE_URL}#person` },
};

const graph: Record<string, unknown>[] = [person, website];

if (ogType === 'article') {
  graph.push({
    '@type': 'Article',
    headline: title,
    description,
    image: ogImageUrl,
    ...(publishedTime ? { datePublished: publishedTime } : {}),
    author: { '@id': `${SITE_URL}#person` },
    publisher: { '@id': `${SITE_URL}#person` },
    url: canonical,
    mainEntityOfPage: canonical,
    isPartOf: { '@id': `${SITE_URL}#website` },
  });
}

const jsonLd = { '@context': 'https://schema.org', '@graph': graph };
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE_NAME} />
    <link rel="canonical" href={canonical} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="sitemap" href={`${import.meta.env.BASE_URL}/sitemap-index.xml`.replace(/\/+/g, '/')} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`.replace(/\/+/g, '/')} />

    <!-- Set theme before paint to avoid flash. -->
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('theme');
          const prefers = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = stored ?? (prefers ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0.5rem;
        background: var(--surface);
        padding: 0.4rem 0.6rem;
        border-radius: 6px;
        border: 1px solid var(--border);
      }
      .skip-link:focus { left: 0.5rem; z-index: 100; }
      main { flex: 1 0 auto; padding: 0 0 2rem; }
    </style>
  </body>
</html>
