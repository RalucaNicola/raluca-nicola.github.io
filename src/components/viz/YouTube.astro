---
interface Props {
  id: string;
  title?: string;
  caption?: string;
  wide?: boolean;
}
const { id, title = 'YouTube video', caption, wide = true } = Astro.props;
---
<figure class:list={[{ 'viz-wide': wide }]}>
  <div class="yt-embed">
    <iframe
      src={`https://www.youtube-nocookie.com/embed/${id}`}
      title={title}
      loading="lazy"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      referrerpolicy="strict-origin-when-cross-origin"
      allowfullscreen
    ></iframe>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .yt-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .yt-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>
