---
import ThemeToggle from './ThemeToggle.astro';

const base = import.meta.env.BASE_URL;
const here = Astro.url.pathname.replace(/\/$/, '') || '/';

function link(path: string) {
  const full = (base + path).replace(/\/+/g, '/').replace(/\/$/, '') || '/';
  return { href: full || '/', active: here === full || (path !== '/' && here.startsWith(full)) };
}

const home = link('/');
const work = link('/work');
const hobbies = link('/hobbies');
const tags = link('/tags');

const logo = `${base}/globe.svg`.replace(/\/+/g, '/');
---

<header class="site-nav">
  <div class="container nav-inner">
    <a class="brand" href={home.href}>
      <!-- <img class="brand-logo" src={logo} alt="" aria-hidden="true" width="28" height="28" /> -->
      Raluca Nicola
    </a>
    <nav aria-label="Primary">
      <ul>
        <li><a href={work.href} class:list={[{ active: work.active }]}>Work</a></li>
        <li><a href={hobbies.href} class:list={[{ active: hobbies.active }]}>Hobbies</a></li>
        <!-- <li><a href={tags.href} class:list={[{ active: tags.active }]}>Tags</a></li> -->
      </ul>
    </nav>
    <ThemeToggle />
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    height: 56px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--text);
    margin-right: auto;
  }
  .brand:hover { color: var(--accent); text-decoration: none; }
  .brand-logo {
    width: 28px;
    height: 28px;
    display: block;
    flex-shrink: 0;
  }
  nav ul {
    display: flex;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
    text-align: center;
    align-items: center;
  }
  nav a {
    color: var(--text-muted);
    padding: 0.4rem 0.7rem;
    border-radius: 8px;
    font-size: 0.95rem;
  }
  nav a:hover { color: var(--text); background: var(--accent-soft); text-decoration: none; }
  nav a.active { color: var(--accent); }

  @media (max-width: 520px) {
    .brand { font-size: 0.95rem; }
    nav a { padding: 0.35rem 0.5rem; font-size: 0.9rem; }
  }
</style>
