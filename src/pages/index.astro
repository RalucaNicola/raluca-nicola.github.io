---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Grid from '~/components/Grid.astro';
import ArticleCard from '~/components/ArticleCard.astro';

const base = import.meta.env.BASE_URL;

type Section = 'data-visualization' | 'drawings';

async function loadSection<S extends Section>(section: S) {
  const entries = await getCollection(section, ({ data }) => !data.draft);
  return entries.map((e) => ({ ...e, section }));
}

const all = (await Promise.all([
  loadSection('data-visualization'),
  loadSection('drawings'),
])).flat();

all.sort((a, b) => +b.data.date - +a.data.date);

function articleHref(section: Section, id: string) {
  return (base + '/' + section + '/' + id).replace(/\/+/g, '/');
}
---

<BaseLayout title="Raluca Nicola" description="Articles on data visualization, watercolor drawings and mountain adventures.">
  <section class="container intro">
    <h2>Hey there, I'm Raluca!</h2> 
    <p>I like to create <a href={`${base}/data-visualization`}>data visualizations</a> about various topics, but mostly geodata and mostly on the web. A few years back I fell in love with <a href={`${base}/drawings`}>watercolor</a>.
    On sunny weekends I'm probably somewhere in the mountains.</p>
  </section>

  <section class="container">
    <Grid>
      {all.map((entry) => (
        <ArticleCard
          href={articleHref(entry.section, entry.id)}
          title={entry.data.title}
          description={entry.data.description}
          date={entry.data.date}
          cover={entry.data.cover}
          coverAlt={entry.data.coverAlt}
          section={entry.section}
        />
      ))}
    </Grid>
  </section>

  <style>
    .intro { margin-bottom: 2rem; }
    .intro p { color: var(--text-muted); font-size: 1.1rem; }
  </style>
</BaseLayout>
