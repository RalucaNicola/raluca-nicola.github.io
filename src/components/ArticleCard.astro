---
import { type Section } from '~/utils/site';

interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  cover?: string;
  coverAlt?: string;
  section?: Section;
  tags?: string[];
}

const { href, title, description, date, cover, coverAlt, tags = [] } = Astro.props;
const dateLabel = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
const base = import.meta.env.BASE_URL;
const coverSrc = cover
  ? (cover.startsWith('http') ? cover : (base + cover).replace(/\/+/g, '/'))
  : undefined;
---

<a class="card" href={href} aria-label={title}>
  <div class="cover">
    {coverSrc ? (
      <img src={coverSrc} alt={coverAlt ?? ''} loading="lazy" decoding="async" />
    ) : (
      <div class="cover-fallback" aria-hidden="true">{tags[0] ?? ''}</div>
    )}
    {tags.length > 0 && (
      <ul class="badges" aria-label="Tags">
        {tags.map((t) => <li class="badge">{t}</li>)}
      </ul>
    )}
  </div>
  <div class="meta">
    <time datetime={date.toISOString()}>{dateLabel}</time>
  </div>
  <h3 class="title">{title}</h3>
  <p class="desc">{description}</p>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    color: var(--text);
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
    border-color: var(--accent);
    text-decoration: none;
  }
  .cover {
    position: relative;
    aspect-ratio: 16 / 10;
    background: var(--accent-soft);
    overflow: hidden;
  }
  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cover-fallback {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    color: var(--accent);
    font-size: 1.1rem;
    letter-spacing: 0.04em;
  }
  .badges {
    position: absolute;
    top: 0.6rem;
    left: 0.6rem;
    right: 0.6rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .badge {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--surface);
    color: var(--text);
    border: 1px solid var(--border);
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
  }
  .meta {
    padding: 0.9rem 1rem 0;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .title {
    margin: 0.3rem 1rem 0;
    font-size: 1.15rem;
  }
  .desc {
    margin: 0.4rem 1rem 1rem;
    color: var(--text-muted);
    font-size: 0.95rem;
    flex: 1;
  }
</style>
