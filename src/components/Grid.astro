---
// Responsive auto-fill grid wrapper.
---
<div class="grid">
  <slot />
</div>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 64px 56px;
  }
  @media (max-width: 680px) {
    .grid { grid-template-columns: 1fr; gap: 54px; }
  }
  /* On very wide screens, fit more (smaller) cards instead of bigger ones. */
  @media (min-width: 100rem) {
    .grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
