---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Grid from '~/components/Grid.astro';
import ArticleCard from '~/components/ArticleCard.astro';
import HeroWash from '~/components/HeroWash.astro';
import { articleHref } from '~/utils/site';

const entries = (await getCollection('work', ({ data }) => !data.draft))
  .sort((a, b) => +b.data.date - +a.data.date);
---

<BaseLayout title="Work" description="Work projects and explorations.">
  <HeroWash>
    <section class="container">
      <header class="page-header">
        <h1>Work</h1>
        <p>Work projects and free time explorations with data.</p>
      </header>
    </section>
  </HeroWash>

  <section class="container">
    <Grid>
      {entries.map((e) => (
        <ArticleCard
          href={articleHref('work', e.id)}
          title={e.data.title}
          description={e.data.description}
          date={e.data.date}
          cover={e.data.cover}
          coverAlt={e.data.coverAlt}
          section="work"
          tags={e.data.tags}
        />
      ))}
    </Grid>
    {entries.length === 0 && <p class="empty">Nothing here yet.</p>}
  </section>

  <style>
    .page-header { padding-top: 3.5rem; margin-bottom: 2rem; }
    .page-header p { color: var(--text-muted); }
    .empty { color: var(--text-muted); }
  </style>
</BaseLayout>
