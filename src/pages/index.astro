---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Grid from '~/components/Grid.astro';
import ArticleCard from '~/components/ArticleCard.astro';
import { loadAllArticles, articleHref, href } from '~/utils/site';

const all = await loadAllArticles();
---

<BaseLayout title="Raluca Nicola" description="Articles on data visualization, watercolor drawings and mountain adventures.">
  <section class="container intro">
    <h2>Hey there, I'm Raluca!</h2>
    <p>I like to create <a href={href('work')}>data visualizations</a> about various topics, but mostly geodata and mostly on the web. A few years back I fell in love with <a href={href('hobbies')}>watercolor</a>.
    On sunny weekends I'm probably somewhere in the mountains.</p>
  </section>

  <section class="container">
    <Grid>
      {all.map((entry) => (
        <ArticleCard
          href={articleHref(entry.section, entry.id)}
          title={entry.data.title}
          description={entry.data.description}
          date={entry.data.date}
          cover={entry.data.cover}
          coverAlt={entry.data.coverAlt}
          section={entry.section}
          tags={entry.data.tags}
        />
      ))}
    </Grid>
  </section>

  <style>
    .intro { margin-bottom: 2rem; }
    .intro p { color: var(--text-muted); font-size: 1.1rem; }
  </style>
</BaseLayout>
