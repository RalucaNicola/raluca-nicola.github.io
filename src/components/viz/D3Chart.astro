---
// Generic D3 mount point. Article registers a render(svg, data, ctx) function
// via window.registerD3(id, fn).

interface Props {
  id: string;
  dataUrl?: string;
  height?: number;
  caption?: string;
}

const { id, dataUrl, height = 360, caption } = Astro.props;
const base = import.meta.env.BASE_URL;
const resolvedUrl = dataUrl
  ? (dataUrl.startsWith('http') ? dataUrl : (base + dataUrl).replace(/\/+/g, '/'))
  : undefined;
---

<figure class="viz-wide">
  <div
    class="d3-host"
    id={id}
    data-data-url={resolvedUrl}
    data-height={height}
    style={`min-height: ${height}px`}
  >
    <noscript>This chart requires JavaScript.</noscript>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .d3-host {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
  }
  .d3-host :global(svg) { width: 100%; height: auto; display: block; }
  .d3-host :global(text) { fill: var(--text); font-size: 12px; }
  .d3-host :global(.axis line),
  .d3-host :global(.axis path) { stroke: var(--border); }
</style>

<script>
  import * as d3 from 'd3';

  type RenderFn = (
    svg: any,
    data: any,
    ctx: { width: number; height: number; d3: typeof d3 }
  ) => void;

  const renderers = new Map<string, RenderFn>();

  (window as any).registerD3 = (id: string, fn: RenderFn) => {
    renderers.set(id, fn);
    const host = document.getElementById(id);
    if (host) render(host as HTMLElement);
  };

  async function render(host: HTMLElement) {
    const fn = renderers.get(host.id);
    if (!fn) return;
    const url = host.dataset.dataUrl;
    const height = Number(host.dataset.height || 360);
    const width = host.clientWidth || 800;
    let data: any = null;
    if (url) {
      try { data = await (await fetch(url)).json(); }
      catch { host.textContent = 'Failed to load data.'; return; }
    }
    host.replaceChildren();
    const svg = d3.select(host)
      .append('svg')
      .attr('viewBox', `0 0 ${width} ${height}`)
      .attr('preserveAspectRatio', 'xMidYMid meet');
    fn(svg, data, { width, height, d3 });
  }

  let t: number | undefined;
  window.addEventListener('resize', () => {
    clearTimeout(t);
    t = window.setTimeout(() => {
      document.querySelectorAll<HTMLElement>('.d3-host').forEach(render);
    }, 150);
  });

  new MutationObserver(() => {
    document.querySelectorAll<HTMLElement>('.d3-host').forEach(render);
  }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  document.querySelectorAll<HTMLElement>('.d3-host').forEach(render);
</script>
