---
// MapLibre GL map. Uses a free demo style by default; pass your own `styleUrl`
// (e.g. a MapTiler / Mapbox / Protomaps style) for production use.

interface Props {
  id: string;
  lng?: number;
  lat?: number;
  zoom?: number;
  height?: number;
  styleUrl?: string;
  geojsonUrl?: string;
  caption?: string;
}

const {
  id,
  lng = 8.55,
  lat = 47.37,
  zoom = 9,
  height = 420,
  styleUrl = 'https://demotiles.maplibre.org/style.json',
  geojsonUrl,
  caption,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const resolvedGeo = geojsonUrl
  ? (geojsonUrl.startsWith('http') ? geojsonUrl : (base + geojsonUrl).replace(/\/+/g, '/'))
  : undefined;
---

<figure class="viz-wide">
  <div
    class="map-host"
    id={id}
    data-lng={lng}
    data-lat={lat}
    data-zoom={zoom}
    data-style-url={styleUrl}
    data-geojson-url={resolvedGeo}
    style={`height: ${height}px`}
  >
    <noscript>This map requires JavaScript.</noscript>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .map-host {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
</style>

<script>
  import maplibregl from 'maplibre-gl';
  import 'maplibre-gl/dist/maplibre-gl.css';

  function init(host: HTMLElement) {
    if (host.dataset.initialized) return;
    host.dataset.initialized = '1';

    const lng = Number(host.dataset.lng);
    const lat = Number(host.dataset.lat);
    const zoom = Number(host.dataset.zoom);
    const styleUrl = host.dataset.styleUrl as string;
    const geojsonUrl = host.dataset.geojsonUrl;

    const map = new maplibregl.Map({
      container: host,
      style: styleUrl,
      center: [lng, lat],
      zoom,
      attributionControl: { compact: true },
    });

    map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-right');

    map.on('load', () => {
      if (!geojsonUrl) return;
      fetch(geojsonUrl).then((r) => r.json()).then((data) => {
        map.addSource('points', { type: 'geojson', data });
        map.addLayer({
          id: 'points-circle',
          type: 'circle',
          source: 'points',
          paint: {
            'circle-radius': 6,
            'circle-color': '#b54a2a',
            'circle-stroke-color': '#ffffff',
            'circle-stroke-width': 1.5,
          },
        });
      }).catch(() => { /* silently ignore data load failures */ });
    });
  }

  document.querySelectorAll<HTMLElement>('.map-host').forEach(init);
</script>
