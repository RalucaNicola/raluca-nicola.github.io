---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <p>© {year} · Built with <a href="https://astro.build">Astro</a>.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding: 1.5rem 0;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .site-footer p { margin: 0; }
</style>
